{
  "name": "acquire-online",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "functions"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:functions": "npm run build --watch --workspace=functions",
    "build:shared": "npm run build --workspace=shared",
    "emulators": "export PATH=\"/opt/homebrew/opt/openjdk@21/bin:$PATH\" && npx -y firebase-tools@latest emulators:start",
    "dev": "npm run build:shared && (npm run dev:functions & npm run emulators & npm run dev:frontend)"
  }
}
